prebuilt_etc {
    name: "com.google.android.projection.gearhead.xml",
    src: "com.google.android.projection.gearhead.xml",
    relative_install_path: "permissions",
}

android_app_import {
    name: "AndroidAutoStub",
    privileged: true,
    presigned: true,
    preprocessed: true,
    required: ["com.google.android.projection.gearhead.xml"],
    apk: "AndroidAutoStubPrebuilt.apk",
}
